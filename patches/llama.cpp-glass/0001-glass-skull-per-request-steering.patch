+json server_task_result_glass_trace::to_json() {
+    json rows = json::array();
+    for (const auto & row : layer_inputs) {
+        json top_dims = json::array();
+        for (const auto & dim : row.top_dims) {
+            top_dims.push_back({
+                {"dimension", dim.first},
+                {"activation", dim.second},
+                {"abs_activation", std::abs(dim.second)},
+            });
+        }
+
+        json item = {
+            {"layer", row.layer},
+            {"stream", row.stream},
+            {"token_index", row.token_index},
+            {"token", row.token},
+            {"norm", row.norm},
+            {"activation_norm", row.norm},
+            {"top_dims", std::move(top_dims)},
+        };
+        if (include_vectors) {
+            item["vector"] = row.vector;
+        }
+        rows.push_back(std::move(item));
+    }
+
+    return json {
+        {"layer_inputs", std::move(rows)},
+        {"activations", {
+            {"supported", true},
+            {"streams", {"resid_pre"}},
+            {"vectors", include_vectors},
+            {"n_embd", n_embd},
+        }},
+    };
+}
