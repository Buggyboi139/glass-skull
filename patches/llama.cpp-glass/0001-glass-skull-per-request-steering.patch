+static json format_response_glass_skull_token_piece(const llama_vocab * vocab, llama_token token) {
+    std::string piece = common_token_to_piece(vocab, token);
+    if (is_valid_utf8(piece)) {
+        return piece;
+    }
+
+    json bytes = json::array();
+    for (unsigned char c : piece) {
+        bytes.push_back(static_cast<int>(c));
+    }
+    return bytes;
+}
