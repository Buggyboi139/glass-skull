--- /dev/null
+++ b/tools/server/tests/unit/test_glass_skull.py
@@ -0,0 +1,102 @@
+import math
+
+import pytest
+
+from utils import *
+
+server = ServerPreset.tinyllama2()
+
+
+@pytest.fixture(autouse=True)
+def create_server():
+    global server
+    server = ServerPreset.tinyllama2()
+
+
+def test_glass_skull_trace_token_only():
+    global server
+    server.start()
+    res = server.make_request("POST", "/glass-skull/trace", data={
+        "prompt": "hello",
+        "with_pieces": True,
+    })
+    assert res.status_code == 200
+    assert res.body["prompt"]["n_tokens_total"] > 0
+    assert res.body["prompt"]["traces"][0]["pieces"]
+    assert res.body["activations"]["supported"] is False
+    assert "layer_inputs" not in res.body
+
+
+def test_glass_skull_trace_layer_inputs():
+    global server
+    server.start()
+    info = server.make_request("GET", "/glass-skull/info")
+    assert info.status_code == 200
+    n_embd = info.body["meta"]["n_embd"]
+
+    res = server.make_request("POST", "/glass-skull/trace", data={
+        "prompt": "hello",
+        "layers": [0],
+        "streams": ["resid_pre"],
+        "with_pieces": True,
+        "include_vectors": True,
+        "top_k": 4,
+    })
+    assert res.status_code == 200
+    assert res.body["activations"]["supported"] is True
+    assert res.body["layer_inputs"]
+
+    prompt_tokens = res.body["prompt"]["traces"][0]["tokens"]
+    rows = [row for row in res.body["layer_inputs"] if row["layer"] == 0]
+    assert len(rows) == len(prompt_tokens)
+    for i, row in enumerate(rows):
+        assert row["stream"] == "resid_pre"
+        assert row["token_index"] == i
+        assert row["token"] == prompt_tokens[i]
+        assert len(row["vector"]) == n_embd
+        assert math.isfinite(row["norm"])
+        assert len(row["top_dims"]) <= 4
+
+
+def test_glass_skull_trace_unsupported_stream_fails_closed():
+    global server
+    server.start()
+    res = server.make_request("POST", "/glass-skull/trace", data={
+        "prompt": "hello",
+        "layers": [0],
+        "streams": ["mlp_out"],
+    })
+    assert res.status_code == 400
+    assert "streams" in res.body["error"]["message"]
+
+
+def test_glass_skull_global_steering_state_and_validation():
+    global server
+    server.start()
+
+    res = server.make_request("GET", "/glass-skull/steering")
+    assert res.status_code == 200
+    assert res.body["enabled"] is False
+    assert res.body["startup_control_vector"]["configured"] is False
+
+    res = server.make_request("POST", "/glass-skull/steering", data={
+        "control_vector": "/tmp/does-not-exist.gguf",
+        "strength": 1.0,
+        "layer_start": 1,
+        "layer_end": 1,
+    })
+    assert res.status_code == 400
+    assert "does not exist" in res.body["error"]["message"]
+
+    res = server.make_request("POST", "/glass-skull/steering", data={
+        "control_vector": "/tmp/does-not-exist.gguf",
+        "strength": 1.0,
+        "layer_start": 2,
+        "layer_end": 1,
+    })
+    assert res.status_code == 400
+    assert "layer range" in res.body["error"]["message"]
+
+    res = server.make_request("DELETE", "/glass-skull/steering")
+    assert res.status_code == 200
+    assert res.body["enabled"] is False
