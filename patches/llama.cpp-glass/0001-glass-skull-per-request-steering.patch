+    void pad_control_vector(common_control_vector_data & cvec) const {
+        if (cvec.n_embd <= 0 || model_tgt == nullptr) {
+            return;
+        }
+
+        const size_t n_layer = static_cast<size_t>(llama_model_n_layer(model_tgt));
+        const size_t want = n_layer * static_cast<size_t>(cvec.n_embd);
+        cvec.data.resize(std::max(cvec.data.size(), want), 0.0f);
+    }
+
+    void load_default_control_vector_state() {
+        default_cvec = { -1, {} };
+        default_cvec_layer_start = -1;
+        default_cvec_layer_end = -1;
+
+        if (params_base.control_vectors.empty()) {
+            return;
+        }
+
+        default_cvec_layer_start = params_base.control_vector_layer_start <= 0 ? 1 : params_base.control_vector_layer_start;
+        default_cvec_layer_end   = params_base.control_vector_layer_end   <= 0 ? llama_model_n_layer(model_tgt) : params_base.control_vector_layer_end;
+        default_cvec = common_control_vector_load(params_base.control_vectors);
+        if (default_cvec.n_embd == -1) {
+            default_cvec.data.clear();
+            default_cvec_layer_start = -1;
+            default_cvec_layer_end = -1;
+            SRV_WRN("%s", "startup control vector restore data could not be loaded; per-request steering will restore to disabled cvec\n");
+            return;
+        }
+        pad_control_vector(default_cvec);
