+static json format_response_glass_skull_info(const server_context_meta & meta, const common_params & params) {
+    return json {
+        {"object", "glass_skull.info"},
+        {"model", {
+            {"id", meta.model_name},
+            {"aliases", meta.model_aliases},
+            {"tags", meta.model_tags},
+            {"path", meta.model_path},
+            {"architecture", meta.model_architecture},
+            {"description", meta.model_description},
