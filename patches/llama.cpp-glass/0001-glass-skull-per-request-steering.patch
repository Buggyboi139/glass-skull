+static std::string server_model_meta_val_str(const llama_model * model, const char * key) {
+    char buf[256];
+    int32_t len = llama_model_meta_val_str(model, key, buf, sizeof(buf));
+    if (len < 0) {
+        return "";
+    }
+    if ((size_t) len < sizeof(buf)) {
+        return std::string(buf);
+    }
+
+    std::vector<char> large_buf(len + 1);
+    len = llama_model_meta_val_str(model, key, large_buf.data(), large_buf.size());
+    return len < 0 ? "" : std::string(large_buf.data());
+}
+
+static std::string server_model_desc_str(const llama_model * model) {
