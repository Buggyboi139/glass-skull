+    bool begin_glass_trace(const server_task & task, std::string & error) {
+        if (task.params.glass_trace.layers.empty()) {
+            error = "glass_skull.trace.layers must contain at least one layer";
+            return false;
+        }
+
+        const int32_t n_layer = llama_model_n_layer(model_tgt);
+        active_glass_trace_layers.clear();
+        for (int32_t layer : task.params.glass_trace.layers) {
+            if (layer < 0 || layer >= n_layer) {
+                error = string_format("glass_skull.trace layer %d is out of range [0, %d)", layer, n_layer);
+                active_glass_trace_layers.clear();
+                return false;
+            }
+            if (std::find(active_glass_trace_layers.begin(), active_glass_trace_layers.end(), layer) == active_glass_trace_layers.end()) {
+                active_glass_trace_layers.push_back(layer);
+            }
+        }
+
+        for (int32_t layer : active_glass_trace_layers) {
+            llama_set_embeddings_layer_inp(ctx_tgt, (uint32_t) layer, true);
+        }
+
+        active_glass_trace = true;
+        active_glass_trace_task = task.id;
+        return true;
+    }
