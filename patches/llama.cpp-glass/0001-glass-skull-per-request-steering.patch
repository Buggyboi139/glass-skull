+        return "";
+    }
+    if ((size_t) len < sizeof(buf)) {
+        return std::string(buf);
+    }
+
+    std::vector<char> large_buf(len + 1);
+    len = llama_model_desc(model, large_buf.data(), large_buf.size());
+    return len < 0 ? "" : std::string(large_buf.data());
+}
