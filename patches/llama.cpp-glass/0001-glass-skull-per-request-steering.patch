+        {"embedding_width", meta.model_n_embd_inp},
+        {"layers", meta.model_n_layer},
+        {"heads", meta.model_n_head},
+        {"kv_heads", meta.model_n_head_kv},
+        {"params", meta.model_n_params},
+        {"size", meta.model_size},
+        {"capabilities", format_response_glass_skull_capabilities(meta, params)},
+        {"meta", {
+            {"vocab_type", meta.model_vocab_type},
