+        int32_t layer_end   = steering.layer_end   <= 0 ? n_layer : steering.layer_end;
+
+        if (layer_start < 1 || layer_end < layer_start || layer_end > n_layer) {
+            error = string_format(
+                "invalid glass_skull.steering layer range [%d, %d]; llama.cpp control vectors use 1-based layers in [1, %d]",
+                layer_start,
+                layer_end,
+                n_layer);
+            return false;
+        }
+
+        if (steering.control_vector.empty()) {
+            error = "glass_skull.steering.control_vector is required";
+            return false;
+        }
+
+        if (!std::filesystem::exists(steering.control_vector)) {
+            error = "glass_skull.steering.control_vector does not exist: " + steering.control_vector;
+            return false;
+        }
+
+        common_control_vector_data cvec = common_control_vector_load({{ steering.strength, steering.control_vector }});
+        if (cvec.n_embd == -1 || cvec.data.empty()) {
+            error = "failed to load glass_skull.steering.control_vector: " + steering.control_vector;
+            return false;
+        }
+
+        pad_control_vector(cvec);
+        if (llama_set_adapter_cvec(ctx_tgt, cvec.data.data(), cvec.data.size(), cvec.n_embd, layer_start, layer_end) != 0) {
+            error = "failed to apply glass_skull.steering.control_vector; vector width may not match the model embedding width";
+            return false;
+        }
+
+        active_request_steering = true;
+        active_request_steering_task = task.id;
+        SRV_INF("enabled per-request Glass Skull steering: task = %d, vector = '%s', strength = %.4f, layers = [%d, %d]\n",
+                task.id,
+                steering.control_vector.c_str(),
+                steering.strength,
+                layer_start,
+                layer_end);
+        return true;
+    }
