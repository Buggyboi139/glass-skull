+            {"audio", meta.has_inp_audio},
+            {"video", meta.has_inp_video},
+        }},
+        {"trace", {
+            {"prompt_tokens", {
+                {"supported", true},
+            }},
+            {"next_token_logits", {
+                {"supported", false},
+                {"reason", "not exposed by this conservative endpoint; use completion APIs with logprobs for generated-token probabilities"},
+            }},
+            {"activations", {
+                {"supported", true},
+                {"streams", {"resid_pre"}},
+                {"vectors", true},
+            }},
+            {"layer_inputs", {
+                {"supported", true},
+                {"streams", {"resid_pre"}},
+                {"vectors", true},
+            }},
+        }},
+        {"steering", {
+            {"per_request", {
+                {"supported", true},
+                {"contract", {
+                    {"request", "glass_skull.steering"},
+                    {"openai_compatible_alternate", "metadata.glass_skull.steering"},
+                    {"control_vector", "path to a llama.cpp GGUF control vector"},
+                    {"strength", "float scale applied while loading the control vector"},
+                    {"layer_start", "1-based inclusive layer start"},
+                    {"layer_end", "1-based inclusive layer end"},
+                }},
+                {"guards", {
+                    {"exclusive_execution", true},
+                    {"prompt_cache_reuse", false},
+                    {"n_cmpl_max", 1},
+                    {"default_control_vector_restore", true},
+                    {"missing_layers_zeroed", true},
+                }},
+            }},
+            {"startup_control_vector", {
+                {"supported", true},
+                {"configured", !params.control_vectors.empty()},
+                {"layer_start", params.control_vector_layer_start},
+                {"layer_end", params.control_vector_layer_end},
+            }},
+            {"global_control_vector", {
+                {"supported", true},
+                {"endpoint", "/glass-skull/steering"},
+                {"layer_range", "1-based inclusive"},
+            }},
+        }},
+    };
+}
