+    static std::vector<std::pair<int32_t, float>> glass_trace_top_dims(const float * data, int32_t n_embd, int32_t top_k) {
+        std::vector<std::pair<int32_t, float>> dims;
+        dims.reserve(n_embd);
+        for (int32_t i = 0; i < n_embd; ++i) {
+            dims.push_back({ i, data[i] });
+        }
+
+        const int32_t n = std::max<int32_t>(0, std::min<int32_t>(top_k, n_embd));
+        auto by_abs = [](const auto & a, const auto & b) {
+            return std::fabs(a.second) > std::fabs(b.second);
+        };
+        if (n < n_embd) {
+            std::partial_sort(dims.begin(), dims.begin() + n, dims.end(), by_abs);
+            dims.resize(n);
+        } else {
+            std::sort(dims.begin(), dims.end(), by_abs);
+        }
+        return dims;
+    }
+
+    void collect_glass_trace_rows(server_slot & slot, const llama_batch & batch_view) {
+        if (!slot.task || slot.task->type != SERVER_TASK_TYPE_GLASS_TRACE) {
+            return;
+        }
+
+        const int32_t n_embd = llama_model_n_embd(model_tgt);
+        for (int32_t layer : slot.task->params.glass_trace.layers) {
+            const float * layer_inp = llama_get_embeddings_layer_inp(ctx_tgt, (uint32_t) layer);
+            if (layer_inp == nullptr) {
+                continue;
+            }
+
+            for (int32_t i = 0; i < batch_view.n_tokens; ++i) {
+                if (batch_view.n_seq_id[i] < 1 || batch_view.seq_id[i][0] != slot.id) {
+                    continue;
+                }
+                const int32_t token_index = batch_view.pos[i];
+                if (token_index < 0 || token_index >= slot.task->n_tokens()) {
+                    continue;
+                }
+
+                const float * row = layer_inp + (size_t) i * n_embd;
+                double sum_sq = 0.0;
+                for (int32_t j = 0; j < n_embd; ++j) {
+                    sum_sq += (double) row[j] * (double) row[j];
+                }
+
+                glass_trace_layer_input item;
+                item.layer = layer;
+                item.stream = "resid_pre";
+                item.token_index = token_index;
+                item.token = batch_view.token[i];
+                item.norm = (float) std::sqrt(sum_sq);
+                item.top_dims = glass_trace_top_dims(row, n_embd, slot.task->params.glass_trace.top_k);
+                if (slot.task->params.glass_trace.include_vectors) {
+                    item.vector.assign(row, row + n_embd);
+                }
+                slot.glass_trace_rows.push_back(std::move(item));
+            }
+        }
+    }
