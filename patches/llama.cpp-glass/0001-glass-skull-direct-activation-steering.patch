+            {"token_index", row.token_index},
+            {"token", row.token},
+            {"norm", row.norm},
+            {"activation_norm", row.norm},
+            {"top_dims", std::move(top_dims)},
+        };
+        if (include_vectors) {
+            item["vector"] = row.vector;
+        }
+        rows.push_back(std::move(item));
+    }
+
+    return json {
+        {"layer_inputs", std::move(rows)},
+        {"activations", {
+            {"supported", true},
+            {"streams", {"resid_pre"}},
+            {"vectors", include_vectors},
+            {"n_embd", n_embd},
+        }},
+    };
+}
