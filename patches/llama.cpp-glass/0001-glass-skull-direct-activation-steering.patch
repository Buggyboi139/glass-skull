+static std::string trim_copy(const std::string & value) {
+    size_t first = 0;
+    while (first < value.size() && std::isspace(static_cast<unsigned char>(value[first]))) {
+        first++;
+    }
+
+    size_t last = value.size();
+    while (last > first && std::isspace(static_cast<unsigned char>(value[last - 1]))) {
+        last--;
+    }
+
+    return value.substr(first, last - first);
+}
+
+static std::string lower_copy(std::string value) {
+    std::transform(value.begin(), value.end(), value.begin(), [](unsigned char ch) {
+        return static_cast<char>(std::tolower(ch));
+    });
+    return value;
+}
+
+static bool all_digits(const std::string & value) {
+    return !value.empty() && std::all_of(value.begin(), value.end(), [](unsigned char ch) {
+        return std::isdigit(ch);
+    });
+}
+
+static task_params::direct_activation_steering_target parse_direct_activation_node_id(const std::string & raw_node_id) {
+    const std::string node_id = trim_copy(raw_node_id);
+    const size_t split = node_id.find("-N");
+    if (node_id.size() < 5 || node_id[0] != 'L' || split == std::string::npos) {
+        throw std::invalid_argument("Malformed activation node ID '" + node_id + "'. Expected L<layer>-N<node>, for example L36-N175.");
+    }
+
+    const std::string layer_value = node_id.substr(1, split - 1);
+    const std::string node_value = node_id.substr(split + 2);
+    if (!all_digits(layer_value) || !all_digits(node_value)) {
+        throw std::invalid_argument("Malformed activation node ID '" + node_id + "'. Expected L<layer>-N<node>, for example L36-N175.");
+    }
+
+    task_params::direct_activation_steering_target target;
+    target.layer = std::stoi(layer_value);
+    target.node = std::stoi(node_value);
+    target.node_start = target.node;
+    target.node_end = target.node;
+    target.node_id = "L" + std::to_string(target.layer) + "-N" + std::to_string(target.node);
+    return target;
+}
+
+static std::vector<std::string> split_direct_activation_target_string(const std::string & raw) {
+    std::vector<std::string> values;
+    std::string current;
+    for (char ch : raw) {
+        if (ch == ',' || ch == '\n' || ch == '\r') {
+            std::string trimmed = trim_copy(current);
+            if (!trimmed.empty()) {
+                values.push_back(trimmed);
+            }
+            current.clear();
+        } else {
+            current.push_back(ch);
+        }
+    }
+
+    std::string trimmed = trim_copy(current);
+    if (!trimmed.empty()) {
+        values.push_back(trimmed);
+    }
+    return values;
+}
+
+static const json * find_glass_skull_steering(const json & data) {
+    if (data.contains("glass_skull") && data.at("glass_skull").is_object()) {
+        const json & glass = data.at("glass_skull");
+        if (glass.contains("steering") && glass.at("steering").is_object()) {
+            return &glass.at("steering");
+        }
+    }
+
+    if (data.contains("glass_skull.steering") && data.at("glass_skull.steering").is_object()) {
+        return &data.at("glass_skull.steering");
+    }
+
+    if (data.contains("metadata") && data.at("metadata").is_object()) {
+        const json & metadata = data.at("metadata");
+        if (metadata.contains("glass_skull") && metadata.at("glass_skull").is_object()) {
+            const json & glass = metadata.at("glass_skull");
+            if (glass.contains("steering") && glass.at("steering").is_object()) {
+                return &glass.at("steering");
+            }
+        }
+        if (metadata.contains("glass_skull.steering") && metadata.at("glass_skull.steering").is_object()) {
+            return &metadata.at("glass_skull.steering");
+        }
+    }
+
+    return nullptr;
+}
+
+static const json * find_glass_skull_direct_activation_steering(const json & data) {
+    if (data.contains("glass_skull") && data.at("glass_skull").is_object()) {
+        const json & glass = data.at("glass_skull");
+        if (glass.contains("direct_activation_steering") && glass.at("direct_activation_steering").is_object()) {
+            return &glass.at("direct_activation_steering");
+        }
+    }
+
+    if (data.contains("glass_skull.direct_activation_steering") && data.at("glass_skull.direct_activation_steering").is_object()) {
+        return &data.at("glass_skull.direct_activation_steering");
+    }
+
+    if (data.contains("metadata") && data.at("metadata").is_object()) {
+        const json & metadata = data.at("metadata");
+        if (metadata.contains("glass_skull") && metadata.at("glass_skull").is_object()) {
+            const json & glass = metadata.at("glass_skull");
+            if (glass.contains("direct_activation_steering") && glass.at("direct_activation_steering").is_object()) {
+                return &glass.at("direct_activation_steering");
+            }
+        }
+        if (metadata.contains("glass_skull.direct_activation_steering") && metadata.at("glass_skull.direct_activation_steering").is_object()) {
+            return &metadata.at("glass_skull.direct_activation_steering");
+        }
+    }
+
+    return nullptr;
+}
+
+static void parse_glass_skull_steering(task_params & params, const json & data) {
+    const json * steering = find_glass_skull_steering(data);
+    if (steering == nullptr) {
+        return;
+    }
+
+    if (!steering->contains("control_vector") || !steering->at("control_vector").is_string()) {
+        throw std::invalid_argument("glass_skull.steering.control_vector must be a non-empty string");
+    }
+
+    params.steering.enabled = true;
+    params.steering.control_vector = steering->at("control_vector").get<std::string>();
+    params.steering.strength = json_value(*steering, "strength", 1.0f);
+    params.steering.layer_start = json_value(*steering, "layer_start", -1);
+    params.steering.layer_end = json_value(*steering, "layer_end", -1);
+
+    if (params.steering.control_vector.empty()) {
+        throw std::invalid_argument("glass_skull.steering.control_vector must be a non-empty string");
+    }
+
+    if ((params.steering.layer_start <= 0) != (params.steering.layer_end <= 0)) {
+        throw std::invalid_argument("glass_skull.steering.layer_start and layer_end must be provided together");
+    }
+
+    if (params.steering.layer_start > 0 && params.steering.layer_end > 0 && params.steering.layer_end < params.steering.layer_start) {
+        throw std::invalid_argument("glass_skull.steering.layer_end must be greater than or equal to layer_start");
+    }
+}
+
+static task_params::direct_activation_steering_target parse_direct_activation_target_object(const json & item) {
+    const std::string node_id = json_value(item, "node_id", json_value(item, "nodeId", std::string()));
+    if (node_id.empty()) {
+        throw std::invalid_argument("glass_skull.direct_activation_steering.targets entries must include node_id in L<layer>-N<node> format");
+    }
+
+    task_params::direct_activation_steering_target target = parse_direct_activation_node_id(node_id);
+
+    if (item.contains("layer")) {
+        if (!item.at("layer").is_number_integer()) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target layer must be an integer");
+        }
+        if (item.at("layer").get<int32_t>() != target.layer) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target layer does not match node_id");
+        }
+    }
+
+    if (item.contains("node")) {
+        if (!item.at("node").is_number_integer()) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target node must be an integer");
+        }
+        if (item.at("node").get<int32_t>() != target.node) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target node does not match node_id");
+        }
+    }
+
+    const json * node_range = nullptr;
+    if (item.contains("node_range")) {
+        node_range = &item.at("node_range");
+    } else if (item.contains("nodeRange")) {
+        node_range = &item.at("nodeRange");
+    }
+
+    if (node_range != nullptr) {
+        if (!node_range->is_array() || node_range->size() != 2 || !node_range->at(0).is_number_integer() || !node_range->at(1).is_number_integer()) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target node_range must be [start, end]");
+        }
+        target.node_start = node_range->at(0).get<int32_t>();
+        target.node_end = node_range->at(1).get<int32_t>();
+        if (target.node_start < 0 || target.node_end < target.node_start) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target node_range must satisfy 0 <= start <= end");
+        }
+        if (target.node_start != target.node) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering target node_range must start at the node_id node");
+        }
+    }
+
+    return target;
+}
+
+static bool direct_activation_ranges_overlap(
+        const task_params::direct_activation_steering_target & lhs,
+        const task_params::direct_activation_steering_target & rhs) {
+    return lhs.layer == rhs.layer && lhs.node_start <= rhs.node_end && rhs.node_start <= lhs.node_end;
+}
+
+static void append_direct_activation_target(
+        std::vector<task_params::direct_activation_steering_target> & targets,
+        std::set<std::string> & seen,
+        task_params::direct_activation_steering_target target) {
+    if (!seen.insert(target.node_id).second) {
+        throw std::invalid_argument("glass_skull.direct_activation_steering contains duplicate target " + target.node_id);
+    }
+    for (const auto & existing : targets) {
+        if (direct_activation_ranges_overlap(existing, target)) {
+            throw std::invalid_argument("glass_skull.direct_activation_steering contains overlapping target ranges at layer L" + std::to_string(target.layer));
+        }
+    }
+    targets.push_back(std::move(target));
+}
+
+static void parse_glass_skull_direct_activation_steering(task_params & params, const json & data) {
+    const json * direct = find_glass_skull_direct_activation_steering(data);
+    if (direct == nullptr) {
+        return;
+    }
+
+    const bool enabled = json_value(*direct, "enabled", true);
+    if (!enabled) {
+        return;
+    }
+
+    if (!direct->contains("targets")) {
+        throw std::invalid_argument("glass_skull.direct_activation_steering.targets is required");
+    }
+
+    std::vector<task_params::direct_activation_steering_target> targets;
+    std::set<std::string> seen;
+    const json & raw_targets = direct->at("targets");
+    if (raw_targets.is_string()) {
+        for (const std::string & node_id : split_direct_activation_target_string(raw_targets.get<std::string>())) {
+            append_direct_activation_target(targets, seen, parse_direct_activation_node_id(node_id));
+        }
+    } else if (raw_targets.is_array()) {
+        for (const json & item : raw_targets) {
+            if (item.is_string()) {
+                append_direct_activation_target(targets, seen, parse_direct_activation_node_id(item.get<std::string>()));
+            } else if (item.is_object()) {
+                append_direct_activation_target(targets, seen, parse_direct_activation_target_object(item));
+            } else {
+                throw std::invalid_argument("glass_skull.direct_activation_steering.targets entries must be node IDs or objects");
+            }
+        }
+    } else {
+        throw std::invalid_argument("glass_skull.direct_activation_steering.targets must be a node ID string or an array");
+    }
+
+    if (targets.empty()) {
+        throw std::invalid_argument("glass_skull.direct_activation_steering.targets must contain at least one activation node ID");
+    }
+
+    const std::string direction = lower_copy(trim_copy(json_value(*direct, "direction", std::string("toward"))));
+    if (direction != "toward" && direction != "away") {
+        throw std::invalid_argument("glass_skull.direct_activation_steering.direction must be 'toward' or 'away'");
+    }
+
+    const std::string token_scope = lower_copy(trim_copy(json_value(*direct, "token_scope", std::string("all"))));
+    if (token_scope != "all" && token_scope != "prompt" && token_scope != "generated") {
+        throw std::invalid_argument("glass_skull.direct_activation_steering.token_scope must be one of: all, prompt, generated");
+    }
+
+    const float magnitude = std::fabs(json_value(*direct, "strength", 1.0f));
+    params.direct_activation_steering.enabled = true;
+    params.direct_activation_steering.targets = std::move(targets);
+    params.direct_activation_steering.direction = direction;
+    params.direct_activation_steering.strength = direction == "toward" ? magnitude : -magnitude;
+    params.direct_activation_steering.token_scope = token_scope;
+}
