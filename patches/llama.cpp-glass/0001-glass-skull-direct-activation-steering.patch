+llm_graph_input_activation_delta::llm_graph_input_activation_delta(
+        llama_activation_delta_runtime * state,
+        int32_t layer,
+        int64_t n_embd,
+        int64_t n_tokens) :
+    state(state),
+    layer(layer),
+    n_embd(n_embd),
+    n_tokens(n_tokens),
+    version(state ? state->version : 0) {
+    values.resize((size_t) n_embd * (size_t) n_tokens, 0.0f);
+}
+
+void llm_graph_input_activation_delta::set_input(const llama_ubatch * ubatch) {
+    std::fill(values.begin(), values.end(), 0.0f);
+
+    if (state && state->enabled && ubatch) {
+        for (const auto & target : state->targets) {
+            if (target.layer != layer) {
+                continue;
+            }
+
+            const int32_t node_start = std::max<int32_t>(0, target.node_start);
+            const int32_t node_end = std::min<int32_t>((int32_t) n_embd - 1, target.node_end);
+            if (node_start > node_end) {
+                continue;
+            }
+
+            for (int64_t i = 0; i < n_tokens && i < ubatch->n_tokens; ++i) {
+                const int32_t token_index = ubatch->pos ? ubatch->pos[i] : (int32_t) i;
+                const bool is_prompt = token_index < state->prompt_tokens;
+                const bool applies =
+                    state->token_scope == LLAMA_ACTIVATION_DELTA_SCOPE_ALL ||
+                    (state->token_scope == LLAMA_ACTIVATION_DELTA_SCOPE_PROMPT && is_prompt) ||
+                    (state->token_scope == LLAMA_ACTIVATION_DELTA_SCOPE_GENERATED && !is_prompt);
+                if (!applies) {
+                    continue;
+                }
+
+                for (int32_t node = node_start; node <= node_end; ++node) {
+                    values[(size_t) i * (size_t) n_embd + (size_t) node] += target.delta;
+                }
+
+                state->hits.push_back({
+                    state->task_id,
+                    layer,
+                    node_start,
+                    node_end,
+                    token_index,
+                    is_prompt ? LLAMA_ACTIVATION_DELTA_SCOPE_PROMPT : LLAMA_ACTIVATION_DELTA_SCOPE_GENERATED,
+                    target.delta,
+                    node_end - node_start + 1,
+                });
+            }
+        }
+    }
+
+    ggml_backend_tensor_set(delta, values.data(), 0, values.size()*sizeof(float));
+}
+
+bool llm_graph_input_activation_delta::can_reuse(const llm_graph_params & params) {
+    return state != nullptr &&
+        params.activation_delta != nullptr &&
+        params.activation_delta == state &&
+        params.activation_delta_version == version &&
+        params.activation_delta->applies_to_layer(layer) &&
+        params.ubatch.n_tokens == n_tokens;
+}
