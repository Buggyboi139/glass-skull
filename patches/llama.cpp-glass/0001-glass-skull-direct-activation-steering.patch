@@ -0,0 +1,338 @@
+import math
+
+import pytest
+
+from utils import *
+
+server = ServerPreset.tinyllama2()
+
+
+@pytest.fixture(autouse=True)
+def create_server():
+    global server
+    server = ServerPreset.tinyllama2()
+
+
+def test_glass_skull_trace_token_only():
+    global server
+    server.start()
+    res = server.make_request("POST", "/glass-skull/trace", data={
+        "prompt": "hello",
+        "with_pieces": True,
+    })
+    assert res.status_code == 200
+    assert res.body["prompt"]["n_tokens_total"] > 0
+    assert res.body["prompt"]["traces"][0]["pieces"]
+    assert res.body["activations"]["supported"] is False
+    assert "layer_inputs" not in res.body
+
+
+def test_glass_skull_trace_layer_inputs():
+    global server
+    server.start()
+    info = server.make_request("GET", "/glass-skull/info")
+    assert info.status_code == 200
+    n_embd = info.body["meta"]["n_embd"]
+
+    res = server.make_request("POST", "/glass-skull/trace", data={
+        "prompt": "hello",
+        "layers": [0],
+        "streams": ["resid_pre"],
+        "with_pieces": True,
+        "include_vectors": True,
+        "top_k": 4,
+    })
+    assert res.status_code == 200
+    assert res.body["activations"]["supported"] is True
+    assert res.body["layer_inputs"]
+
+    prompt_tokens = res.body["prompt"]["traces"][0]["tokens"]
+    rows = [row for row in res.body["layer_inputs"] if row["layer"] == 0]
+    assert len(rows) == len(prompt_tokens)
+    for i, row in enumerate(rows):
+        assert row["stream"] == "resid_pre"
+        assert row["token_index"] == i
+        assert row["token"] == prompt_tokens[i]
+        assert len(row["vector"]) == n_embd
+        assert math.isfinite(row["norm"])
+        assert len(row["top_dims"]) <= 4
+
+
+def test_glass_skull_trace_unsupported_stream_fails_closed():
+    global server
+    server.start()
+    res = server.make_request("POST", "/glass-skull/trace", data={
+        "prompt": "hello",
+        "layers": [0],
+        "streams": ["mlp_out"],
+    })
+    assert res.status_code == 400
+    assert "streams" in res.body["error"]["message"]
+
+
+def test_glass_skull_global_steering_state_and_validation():
+    global server
+    server.start()
+
+    res = server.make_request("GET", "/glass-skull/steering")
+    assert res.status_code == 200
+    assert res.body["enabled"] is False
+    assert res.body["startup_control_vector"]["configured"] is False
+
+    res = server.make_request("POST", "/glass-skull/steering", data={
+        "control_vector": "/tmp/does-not-exist.gguf",
+        "strength": 1.0,
+        "layer_start": 1,
+        "layer_end": 1,
+    })
+    assert res.status_code == 400
+    assert "does not exist" in res.body["error"]["message"]
+
+    res = server.make_request("POST", "/glass-skull/steering", data={
+        "control_vector": "/tmp/does-not-exist.gguf",
+        "strength": 1.0,
+        "layer_start": 2,
+        "layer_end": 1,
+    })
+    assert res.status_code == 400
+    assert "layer range" in res.body["error"]["message"]
+
+    res = server.make_request("DELETE", "/glass-skull/steering")
+    assert res.status_code == 200
+    assert res.body["enabled"] is False
+
+
+def test_glass_skull_direct_activation_steering_contract_and_request_parsing():
+    global server
+    server.start()
+
+    info = server.make_request("GET", "/glass-skull/info")
+    assert info.status_code == 200
+    direct = info.body["capabilities"]["direct_activation_steering"]
+    assert direct["supported"] is True
+    assert direct["mechanism"] == "hook_level_activation_delta"
+    assert direct["contract"]["request"] == "glass_skull.direct_activation_steering"
+    assert direct["contract"]["openai_compatible_alternate"] == "metadata.glass_skull.direct_activation_steering"
+    assert direct["map_identity"] == {
+        "node_id_format": "L<layer>-N<node>",
+        "layer_base": 0,
+        "activation_space": "same tensor used by Activation Map",
+        "tensor_stream": "resid_pre",
+        "node_axis": "embedding/channel dimension",
+        "node_range": "inclusive",
+    }
+    assert direct["token_scope"] == {"all": True, "prompt": True, "generated": True}
+    assert direct["multiple_targets"] is True
+
+    res = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 0,
+        "verbose": True,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": [
+                    {"node_id": "L0-N0"},
+                    {"node_id": "L0-N1", "node_range": [1, 1]},
+                ],
+                "direction": "Away",
+                "strength": 0.2,
+                "token_scope": "generated",
+            },
+        },
+    })
+    assert res.status_code == 200
+    parsed = res.body["generation_settings"]["glass_skull"]["direct_activation_steering"]
+    assert parsed["enabled"] is True
+    assert parsed["strength"] == -0.2
+    assert parsed["direction"] == "away"
+    assert parsed["token_scope"] == "generated"
+    assert [target["node_id"] for target in parsed["targets"]] == ["L0-N0", "L0-N1"]
+    assert "hook" not in parsed
+
+
+def test_glass_skull_direct_activation_steering_metadata_alternate_and_validation():
+    global server
+    server.start()
+
+    res = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 0,
+        "verbose": True,
+        "metadata": {
+            "glass_skull": {
+                "direct_activation_steering": {
+                    "enabled": True,
+                    "targets": "L0-N0,L0-N1",
+                    "direction": "Toward",
+                    "strength": 0.4,
+                    "token_scope": "all",
+                },
+            },
+        },
+    })
+    assert res.status_code == 200
+    parsed = res.body["generation_settings"]["glass_skull"]["direct_activation_steering"]
+    assert parsed["strength"] == 0.4
+    assert [target["node_id"] for target in parsed["targets"]] == ["L0-N0", "L0-N1"]
+
+    res = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 0,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": "L0:N0",
+                "direction": "Toward",
+                "strength": 0.4,
+                "token_scope": "all",
+            },
+        },
+    })
+    assert res.status_code == 400
+    assert "Malformed activation node ID" in res.body["error"]["message"]
+
+    duplicate = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 0,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": "L0-N0,L0-N0",
+                "direction": "Toward",
+                "strength": 0.4,
+                "token_scope": "all",
+            },
+        },
+    })
+    assert duplicate.status_code == 400
+    assert "duplicate" in duplicate.body["error"]["message"].lower()
+
+    mismatched_range = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 0,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": [{"node_id": "L0-N0", "node_range": [1, 2]}],
+                "direction": "Toward",
+                "strength": 0.4,
+                "token_scope": "all",
+            },
+        },
+    })
+    assert mismatched_range.status_code == 400
+    assert "node_range must start at the node_id node" in mismatched_range.body["error"]["message"]
+
+    overlapping_range = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 0,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": [
+                    {"node_id": "L0-N0", "node_range": [0, 2]},
+                    {"node_id": "L0-N1", "node_range": [1, 1]},
+                ],
+                "direction": "Toward",
+                "strength": 0.4,
+                "token_scope": "all",
+            },
+        },
+    })
+    assert overlapping_range.status_code == 400
+    assert "overlapping target ranges" in overlapping_range.body["error"]["message"]
+
+
+def _direct_hook_events(response_body):
+    parsed = response_body["generation_settings"]["glass_skull"]["direct_activation_steering"]
+    hook = parsed["hook"]
+    assert hook["mechanism"] == "hook_level_activation_delta"
+    assert hook["activation_space"] == "resid_pre"
+    assert hook["total_hit_count"] > 0
+    assert hook["events"]
+    return hook["events"]
+
+
+def test_glass_skull_direct_activation_steering_hook_hits_prompt_scope_exact_node():
+    global server
+    server.start()
+
+    res = server.make_request("POST", "/completion", data={
+        "prompt": "hello world",
+        "n_predict": 1,
+        "verbose": True,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": [{"node_id": "L0-N0", "node_range": [0, 0]}],
+                "direction": "Toward",
+                "strength": 0.4,
+                "token_scope": "prompt",
+            },
+        },
+    })
+    assert res.status_code == 200
+    events = _direct_hook_events(res.body)
+    assert {event["layer"] for event in events} == {0}
+    assert {event["node_start"] for event in events} == {0}
+    assert {event["node_end"] for event in events} == {0}
+    assert {event["token_phase"] for event in events} == {"prompt"}
+    assert {event["signed_delta"] for event in events} == {0.4}
+    assert all(event["token_index"] < res.body["tokens_evaluated"] for event in events)
+
+
+def test_glass_skull_direct_activation_steering_hook_hits_generated_scope_and_ranges():
+    global server
+    server.start()
+
+    res = server.make_request("POST", "/completion", data={
+        "prompt": "hello",
+        "n_predict": 2,
+        "verbose": True,
+        "glass_skull": {
+            "direct_activation_steering": {
+                "enabled": True,
+                "targets": [
+                    {"node_id": "L0-N0", "node_range": [0, 1]},
+                    {"node_id": "L1-N2", "node_range": [2, 2]},
+                ],
+                "direction": "Away",
+                "strength": 0.25,
+                "token_scope": "generated",
+            },
+        },
+    })
+    assert res.status_code == 200
+    events = _direct_hook_events(res.body)
+    assert {event["token_phase"] for event in events} == {"generated"}
+    assert all(event["token_index"] >= res.body["tokens_evaluated"] for event in events)
+    assert {
+        (event["layer"], event["node_start"], event["node_end"], event["signed_delta"])
+        for event in events
+    } == {(0, 0, 1, -0.25), (1, 2, 2, -0.25)}
+    assert all(event["layer"] != 2 for event in events)
+    assert all(not (event["layer"] == 0 and event["node_start"] <= 2 <= event["node_end"]) for event in events)
+
+
+def test_glass_skull_direct_activation_steering_disabled_records_no_hook_hits():
