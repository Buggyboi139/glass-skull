+    bool apply_control_vector(const common_control_vector_data & cvec, int32_t layer_start, int32_t layer_end) {
+        if (cvec.n_embd > 0 && !cvec.data.empty()) {
+            return llama_set_adapter_cvec(
+                ctx_tgt,
+                cvec.data.data(),
+                cvec.data.size(),
+                cvec.n_embd,
+                layer_start,
+                layer_end) == 0;
+        }
+
+        return llama_set_adapter_cvec(ctx_tgt, nullptr, 0, 0, -1, -1) == 0;
+    }
+
+    bool restore_default_control_vector() {
