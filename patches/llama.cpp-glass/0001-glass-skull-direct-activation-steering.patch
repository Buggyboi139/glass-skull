+    bool begin_direct_activation_steering(const server_task & task, std::string & error) {
+        GGML_ASSERT(task.params.direct_activation_steering.enabled);
+
+        const auto & steering = task.params.direct_activation_steering;
+        const int32_t n_layer = llama_model_n_layer(model_tgt);
+        const int32_t n_embd = llama_model_n_embd(model_tgt);
+
+        if (n_layer <= 0 || n_embd <= 0) {
+            error = "model dimensions are unavailable for glass_skull.direct_activation_steering";
+            return false;
+        }
+
+        std::vector<llama_activation_delta_target> hook_targets;
+        hook_targets.reserve(steering.targets.size());
+
+        for (const auto & target : steering.targets) {
+            if (target.layer < 0 || target.layer >= n_layer) {
+                error = string_format(
+                    "glass_skull.direct_activation_steering target %s is outside model layers L0-L%d",
+                    target.node_id.c_str(),
+                    n_layer - 1);
+                return false;
+            }
+
+            if (target.node_start < 0 || target.node_end < target.node_start || target.node_end >= n_embd) {
+                error = string_format(
+                    "glass_skull.direct_activation_steering target %s node range [%d, %d] is outside model width [0, %d]",
+                    target.node_id.c_str(),
+                    target.node_start,
+                    target.node_end,
+                    n_embd - 1);
+                return false;
+            }
+
+            hook_targets.push_back({
+                target.layer,
+                target.node_start,
+                target.node_end,
+                steering.strength,
+            });
+        }
+
+        llama_activation_delta_token_scope scope = LLAMA_ACTIVATION_DELTA_SCOPE_ALL;
+        if (steering.token_scope == "prompt") {
+            scope = LLAMA_ACTIVATION_DELTA_SCOPE_PROMPT;
+        } else if (steering.token_scope == "generated") {
+            scope = LLAMA_ACTIVATION_DELTA_SCOPE_GENERATED;
+        }
+
+        llama_set_activation_delta(ctx_tgt, task.id, hook_targets.data(), hook_targets.size(), task.n_tokens(), scope);
+        active_request_steering = true;
+        active_request_direct_activation_steering = true;
+        active_request_steering_task = task.id;
+        SRV_INF("enabled hook-level Glass Skull activation steering: task = %d, targets = %zu, strength = %.4f, token_scope = %s, activation_space = resid_pre\n",
+                task.id,
+                steering.targets.size(),
+                steering.strength,
+                steering.token_scope.c_str());
+        return true;
+    }
+
+    bool begin_request_steering(const server_task & task, std::string & error) {
+        GGML_ASSERT(task.params.has_request_steering());
+
+        if (task.params.direct_activation_steering.enabled) {
+            return begin_direct_activation_steering(task, error);
+        }
+
+        const auto & steering = task.params.steering;
+        const int32_t n_layer = llama_model_n_layer(model_tgt);
+        int32_t layer_start = steering.layer_start <= 0 ? 1 : steering.layer_start;
+        int32_t layer_end   = steering.layer_end   <= 0 ? n_layer : steering.layer_end;
+
+        if (layer_start < 1 || layer_end < layer_start || layer_end > n_layer) {
+            error = string_format(
+                "invalid glass_skull.steering layer range [%d, %d]; llama.cpp control vectors use 1-based layers in [1, %d]",
+                layer_start,
+                layer_end,
+                n_layer);
+            return false;
+        }
+
+        if (steering.control_vector.empty()) {
+            error = "glass_skull.steering.control_vector is required";
+            return false;
+        }
+
+        if (!std::filesystem::exists(steering.control_vector)) {
+            error = "glass_skull.steering.control_vector does not exist: " + steering.control_vector;
+            return false;
+        }
+
+        common_control_vector_data cvec = common_control_vector_load({{ steering.strength, steering.control_vector }});
+        if (cvec.n_embd == -1 || cvec.data.empty()) {
+            error = "failed to load glass_skull.steering.control_vector: " + steering.control_vector;
+            return false;
+        }
+
+        pad_control_vector(cvec);
+        if (llama_set_adapter_cvec(ctx_tgt, cvec.data.data(), cvec.data.size(), cvec.n_embd, layer_start, layer_end) != 0) {
+            error = "failed to apply glass_skull.steering.control_vector; vector width may not match the model embedding width";
+            return false;
+        }
+
+        active_request_steering = true;
+        active_request_direct_activation_steering = false;
+        active_request_steering_task = task.id;
+        SRV_INF("enabled per-request Glass Skull steering: task = %d, vector = '%s', strength = %.4f, layers = [%d, %d]\n",
+                task.id,
+                steering.control_vector.c_str(),
+                steering.strength,
+                layer_start,
+                layer_end);
+        return true;
+    }
+
+    void finish_request_steering(int id_task) {
+        if (!active_request_steering || active_request_steering_task != id_task) {
+            return;
+        }
+
+        if (active_request_direct_activation_steering) {
+            llama_clear_activation_delta(ctx_tgt);
+            SRV_INF("cleared hook-level direct activation steering after task %d\n", id_task);
+        } else {
+            if (!restore_effective_control_vector()) {
+                SRV_ERR("failed to restore effective control vector after task %d\n", id_task);
+            } else {
+                SRV_INF("restored effective control vector after task %d\n", id_task);
+            }
+        }
+
+        active_request_steering = false;
+        active_request_direct_activation_steering = false;
+        active_request_steering_task = -1;
+    }
