+ggml_tensor * llm_graph_context::build_activation_delta(
+         ggml_tensor * cur,
+                 int   il) const {
+    if (!activation_delta || !activation_delta->applies_to_layer(il)) {
+        return cur;
+    }
+
+    auto inp = std::make_unique<llm_graph_input_activation_delta>(activation_delta, il, cur->ne[0], cur->ne[1]);
+    inp->delta = ggml_new_tensor_2d(ctx0, GGML_TYPE_F32, cur->ne[0], cur->ne[1]);
+    ggml_set_input(inp->delta);
+    ggml_format_name(inp->delta, "glass_skull_activation_delta_l%d", il);
+
+    ggml_tensor * delta = inp->delta;
+    res->add_input(std::move(inp));
+
+    cur = ggml_add(ctx0, cur, delta);
+    cb(cur, "glass_skull_activation_delta", il);
+    return cur;
+}
